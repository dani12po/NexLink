# ============================================================
# NEXLINK — Environment Variables Template
# Copy ke .env.local dan isi nilainya
# Updated: 2026-04-25
# ============================================================

# ─── App ─────────────────────────────────────────────────────
APP_URL=https://your-app.vercel.app

# ─── Arc Testnet ─────────────────────────────────────────────
ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network

# USDC contract di Arc (6 decimals, native token)
ARC_USDC_ERC20=0x3600000000000000000000000000000000000000
ARC_USDC=0x3600000000000000000000000000000000000000

# Reward faucet
REWARD_USDC=10
NEXT_PUBLIC_REWARD_USDC=10

# ─── Treasury Private Key (server-only) ──────────────────────
# Dipakai: /api/bridge/mint, /api/faucet, /api/free-claim, /api/claim
# Generate: cast wallet new  ATAU  node -e "console.log(require('ethers').Wallet.createRandom().privateKey)"
ARC_TREASURY_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_64_HEX_CHARS

# ─── Base Mainnet (Paid Faucet) ──────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# Treasury address di Base (penerima pembayaran faucet)
TREASURY=0xYOUR_TREASURY_ADDRESS
TREASURY_BASE_ADDRESS=0xYOUR_TREASURY_ADDRESS
NEXT_PUBLIC_TREASURY=0xYOUR_TREASURY_ADDRESS
NEXT_PUBLIC_TREASURY_BASE_ADDRESS=0xYOUR_TREASURY_ADDRESS

# USDC di Base — semua alias dibutuhkan oleh berbagai file
BASE_USDC=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_BASE=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
NEXT_PUBLIC_BASE_USDC=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
NEXT_PUBLIC_USDC_BASE=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Harga faucet berbayar
PAY_USDC=0.15
PAY_ETH=0.00005
NEXT_PUBLIC_PAY_USDC=0.15
NEXT_PUBLIC_PAY_ETH=0.00005
NEXT_PUBLIC_PAYMENT_USDC=0.15

# Cooldown wallet claim (detik)
WALLET_CLAIM_COOLDOWN_SEC=7200

# ─── Free Claim ───────────────────────────────────────────────
FREE_CLAIM_COOLDOWN_MS=7200000
FREE_CLAIM_REWARD_AMOUNT=5

# ─── Circle API Keys (server-only) ───────────────────────────
# Dapatkan dari: https://console.circle.com
CIRCLE_TEST_API_KEY=TEST_API_KEY:your_key_id:your_key_secret

# ─── Circle App Kit (browser — untuk swap via StableFX) ──────
NEXT_PUBLIC_KIT_KEY=KIT_KEY:your_key_id:your_key_secret
NEXT_PUBLIC_CIRCLE_KIT_KEY=KIT_KEY:your_key_id:your_key_secret

# ─── x402 Nanopayment ────────────────────────────────────────
X402_RECEIVER_ADDRESS=0xYOUR_RECEIVER_ADDRESS
X402_PRICE_USDC=0.001
# CIRCLE_GATEWAY_API_KEY=TEST_API_KEY:your_key_here

# ─── Twitter/X OAuth (untuk follow-gate) ─────────────────────
# Dapatkan dari: https://developer.twitter.com/en/portal
# X_CLIENT_ID=your_client_id
# X_CLIENT_SECRET=your_client_secret
# X_TARGET_USER_ID=your_twitter_user_id

# ─── CORS (opsional) ─────────────────────────────────────────
# ALLOWED_ORIGINS=https://other-domain.com

# ─── Storage (Vercel KV) ──────────────────────────────────────
# Tanpa ini, rate-limit hanya in-memory (reset tiap cold start)
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...

# ─── Bridge CCTP V2 (opsional override) ──────────────────────
# Default sudah di-hardcode di lib/arcChain.ts
# NEXT_PUBLIC_ARC_TOKEN_MESSENGER=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA
# NEXT_PUBLIC_ARC_MESSAGE_TRANSMITTER=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275

# ─── Sepolia RPC (server-side bridge mint) ───────────────────
SEPOLIA_RPC_URL=https://rpc.ankr.com/eth_sepolia

# ─── Circle Iris API (server-side attestation proxy) ─────────
# Default: https://iris-api-sandbox.circle.com (testnet)
# Override jika server tidak bisa reach domain Circle
# Diagnosa: /api/bridge/attestation?test=1
IRIS_API_URL=https://iris-api-sandbox.circle.com

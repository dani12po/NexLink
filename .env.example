# ============================================================
# NEXLINK — Environment Variables Template
# Copy ke .env.local dan isi nilainya
# Updated: 2026-04-23
# ============================================================

# App URL (no trailing slash)
APP_URL=https://your-app.vercel.app

# ─── Arc Testnet ─────────────────────────────────────────────
# Sumber: https://docs.arc.network/arc/references/connect-to-arc
ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network

# USDC contract — https://docs.arc.network/arc/references/contract-addresses
# Gunakan ARC_USDC_ERC20 (standar baru) — ARC_USDC untuk backward compat
ARC_USDC_ERC20=0x3600000000000000000000000000000000000000
ARC_USDC=0x3600000000000000000000000000000000000000

# Treasury private key untuk kirim reward faucet (server-only)
# SATU private key untuk semua operasi kirim USDC
ARC_TREASURY_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Reward amount untuk paid faucet (/api/faucet)
REWARD_USDC=10

# ─── Free Claim ───────────────────────────────────────────────
FREE_CLAIM_COOLDOWN_MS=7200000
FREE_CLAIM_REWARD_AMOUNT=5

# ─── Storage (Vercel KV) ──────────────────────────────────────
# Jika tidak diset, fallback ke in-memory (tidak persistent di serverless)
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...

# ─── x402 Nanopayment ────────────────────────────────────────
X402_RECEIVER_ADDRESS=0xYOUR_RECEIVER_ADDRESS
X402_PRICE_USDC=0.001

# ─── Circle App Kit (opsional — untuk swap via StableFX RFQ) ─
# Format: KIT_KEY:keyId:keySecret
# Dapatkan dari: https://console.circle.com/w3s/keys#kit-keys
# NEXT_PUBLIC_KIT_KEY=KIT_KEY:your_key_id:your_key_secret

# ─── Paid Faucet (Base chain) ────────────────────────────────
# Digunakan oleh /api/claim — verifikasi pembayaran di Base sebelum kirim USDC di Arc
BASE_RPC_URL=https://mainnet.base.org
TREASURY=0xYOUR_TREASURY_ADDRESS
BASE_USDC=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
PAY_USDC=0.15
WALLET_CLAIM_COOLDOWN_SEC=7200
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_TREASURY=0xYOUR_TREASURY_ADDRESS
NEXT_PUBLIC_BASE_USDC=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ─── CCTP contract overrides (opsional) ──────────────────────
# Default sudah di-hardcode di lib/arcChain.ts
# Uncomment hanya jika address berubah:
# NEXT_PUBLIC_ARC_TOKEN_MESSENGER=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA
# NEXT_PUBLIC_ARC_MESSAGE_TRANSMITTER=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275

# ─── DEPRECATED — jangan gunakan lagi ────────────────────────
# ADMIN_PRIVATE_KEY     → gunakan ARC_TREASURY_PRIVATE_KEY
# FAUCET_PRIVATE_KEY    → gunakan ARC_TREASURY_PRIVATE_KEY
# FREE_CLAIM_PRIVATE_KEY → gunakan ARC_TREASURY_PRIVATE_KEY
# ARC_USDC_ADDRESS      → gunakan ARC_USDC_ERC20
# USDC_ADDRESS          → gunakan ARC_USDC_ERC20
# SUPABASE_URL          → tidak digunakan lagi (storage pindah ke Vercel KV)
# SUPABASE_SERVICE_ROLE_KEY → tidak digunakan lagi

# ─── BridgeKit Fallback ───────────────────────────────────────────────────
# RPC untuk BridgeKit server-side (bisa berbeda dari NEXT_PUBLIC_)
SEPOLIA_RPC_URL=https://rpc.ankr.com/eth_sepolia

# Proxy untuk akses Iris API jika diblokir (opsional)
# Format: http://host:port atau http://user:pass@host:port
# BRIDGE_PROXY_URL=http://1.2.3.4:8080
# Atau taruh list proxy di proxy.txt (satu per baris)
